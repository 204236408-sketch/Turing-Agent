APP_ENV=dev
DEBUG=true

# ── 数据库 ──────────────────────────────────────────
# 开箱即用：默认 SQLite。演示和小组开发不用先装 MySQL。
DATABASE_URL=sqlite:///./turing408.db
# 需要 MySQL 时启用这一行，并注释 DATABASE_URL 或保持 MYSQL_URL 优先。
# MYSQL_URL=mysql+pymysql://root:password@127.0.0.1:3306/yantu408?charset=utf8mb4

# ── 安全 ────────────────────────────────────────────
# !!! 生产环境必须改 !!!
# 用以下命令生成强密钥（至少 32 字符）:
#   python -c "import secrets; print(secrets.token_hex(32))"
# 或 PowerShell:
#   [System.Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).ToLower()
SECRET_KEY=please-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ────────────────────────────────────────────
# 开发环境用 * (允许所有来源)
# 生产环境必须设置为具体域名，多个用逗号分隔:
# CORS_ORIGINS=https://example.com,https://admin.example.com
CORS_ORIGINS=*

# ── LLM ─────────────────────────────────────────────
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen3.5-9B
LLM_TIMEOUT_SECONDS=90

# ── 存储路径 ────────────────────────────────────────
CHROMA_PATH=./vector_store/chroma
UPLOAD_DIR=./uploads
REPORT_DIR=./outputs/reports
